<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <style name="TermuxAlertDialogStyle" parent="@android:style/Theme.Material.Light.Dialog.Alert">
        <!-- Seen in buttons on alert dialog: -->
        <item name="android:colorAccent">#212121</item>
    </style>

    <style name="Theme.TermuxActivity.DayNight.NoActionBar"
        parent="Theme.AppCompat.DayNight.NoActionBar">

        <item name="termuxActivityDrawerBackground">@color/background</item>
        <item name="termuxActivityDrawerImageTint">@color/white</item>

    </style>

    <style name="Theme.TermuxApp.DayNight.NoActionBar"
        parent="Theme.AppCompat.DayNight.NoActionBar">

        <item name="termuxActivityDrawerBackground">@color/background</item>
        <item name="termuxActivityDrawerImageTint">@color/white</item>

    </style>

    <style name="Theme.TermuxApp.DayNight.DarkActionBar"
        parent="Theme.AppCompat.DayNight.DarkActionBar" />

    <style name="TermuxActivity.Drawer.ButtonBarStyle.Light" parent="@style/Widget.AppCompat.Button.Borderless">

        <item name="android:textColor">@color/black</item>

    </style>

    <style name="TermuxActivity.Drawer.ButtonBarStyle.Dark" parent="@style/Widget.AppCompat.Button.Borderless">

        <item name="android:textColor">@color/white</item>

    </style>

</resources>
